{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Categories for organizing articles (matches homepage sections)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "categoryImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "displayname": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text",
      "required": false
    },
    "order": {
      "type": "integer",
      "required": false,
      "default": 0
    },
    "enabled": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "articles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::article.article",
      "mappedBy": "category"
    },
    "relatedcategories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::category.category"
    },
    "relatedtaggroups": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tag-group.tag-group"
    },
    "calculators": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::calculator.calculator",
      "mappedBy": "category"
    },
    "toparticle": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::article.article"
    },
    "populartags": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tag.tag"
    },
    "categorycontenttype": {
      "type": "enumeration",
      "enum": ["articles", "calculators", "rates"],
      "required": true
    }
  }
}
