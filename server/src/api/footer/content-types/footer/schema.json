{
  "kind": "singleType",
  "collectionName": "footers",
  "info": {
    "singularName": "footer",
    "pluralName": "footers",
    "displayName": "Footer",
    "description": "Site footer with multiple sections"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "logoText": {
      "type": "string",
      "default": "Unicat",
      "required": false
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "description": {
      "type": "text",
      "required": false
    },
    "socialLinks": {
      "type": "component",
      "component": "layout.social-link",
      "repeatable": true
    },
    "contactInfo": {
      "type": "component",
      "component": "layout.contact-info",
      "repeatable": false
    },
    "quickLinksColumn1": {
      "type": "component",
      "component": "layout.link",
      "repeatable": true
    },
    "quickLinksColumn2": {
      "type": "component",
      "component": "layout.link",
      "repeatable": true
    },
    "mobileTitle": {
      "type": "string",
      "default": "Mobile"
    },
    "appDownloads": {
      "type": "component",
      "component": "layout.app-download",
      "repeatable": true
    },
    "copyrightText": {
      "type": "string",
      "required": false
    }
  }
}
