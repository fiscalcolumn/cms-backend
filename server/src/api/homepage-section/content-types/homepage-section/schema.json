{
  "kind": "collectionType",
  "collectionName": "homepage_sections",
  "info": {
    "singularName": "homepage-section",
    "pluralName": "homepage-sections",
    "displayName": "Homepage Section",
    "description": "Dynamic sections for the homepage with featured items and category reference"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category"
    },
    "buttonText": {
      "type": "string",
      "default": "view all"
    },
    "order": {
      "type": "integer",
      "required": true,
      "default": 0,
      "min": 0
    },
    "enabled": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "sectionStyle": {
      "type": "enumeration",
      "required": true,
      "default": "lead-story",
      "enum": [
        "lead-story",
        "mosaic",
        "scroll-row",
        "digest"
      ]
    },
    "itemsToShow": {
      "type": "integer",
      "default": 6,
      "min": 1,
      "max": 20
    }
  }
}
