{
  "kind": "collectionType",
  "collectionName": "glossaries",
  "info": {
    "singularName": "glossary",
    "pluralName": "glossaries",
    "displayName": "Glossary",
    "description": "Financial term definitions — What is SIP, CAGR, P/E ratio, etc."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "term": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "term",
      "required": true
    },
    "definition": {
      "type": "richtext",
      "required": true
    },
    "shortDefinition": {
      "type": "text",
      "maxLength": 300
    },
    "category": {
      "type": "enumeration",
      "enum": ["investing", "trading", "banking", "insurance", "taxation", "general"],
      "default": "general",
      "required": true
    },
    "relatedTerms": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::glossary.glossary"
    },
    "relatedArticles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article"
    },
    "metaTitle": {
      "type": "string",
      "maxLength": 70
    },
    "metaDescription": {
      "type": "text",
      "maxLength": 160
    }
  }
}
