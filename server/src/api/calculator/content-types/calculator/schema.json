{
  "kind": "collectionType",
  "collectionName": "calculators",
  "info": {
    "singularName": "calculator",
    "pluralName": "calculators",
    "displayName": "Calculator",
    "description": "Financial and Health calculators"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "icon": {
      "type": "string",
      "default": "fa-calculator"
    },
    "iconColor": {
      "type": "string",
      "default": "#14bdee"
    },
    "excerpt": {
      "type": "text",
      "maxLength": 200
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "description": {
      "type": "richtext"
    },
    "formulaExplanation": {
      "type": "richtext"
    },
    "howToUse": {
      "type": "richtext"
    },
    "disclaimer": {
      "type": "text"
    },
    "metaTitle": {
      "type": "string",
      "maxLength": 70
    },
    "metaDescription": {
      "type": "text",
      "maxLength": 160
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "faqs": {
      "type": "component",
      "component": "calculator.faq",
      "repeatable": true
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "calculators"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag"
    },
    "enableCalculator": {
      "type": "boolean",
      "default": true
    },
    "isTrending": {
      "type": "boolean",
      "default": false
    },
    "views": {
      "type": "biginteger",
      "default": "5"
    },
    "calculatorcategory": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::calculator-category-type.calculator-category-type"
    }
  }
}
